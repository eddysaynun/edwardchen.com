---
import { sortPostsByPinnedAndDate, groupPostsByYearMonth } from '../utils/posts';
import T from './T.astro';
import { DEFAULT_LANG } from '../utils/i18n';

interface Props {
  posts: {
    data: {
      pubDate?: Date;
      title: string;
      description?: string;
      tags: string[];
      pinned?: boolean;
    };
    slug: string;
  }[];
}

const { posts } = Astro.props;
const lang = DEFAULT_LANG;

// 排序并分组
const sortedPosts = sortPostsByPinnedAndDate(posts);
const groupedPosts = groupPostsByYearMonth(sortedPosts);

// 获取所有年月键（按时间倒序）
const yearMonths = Object.keys(groupedPosts).sort((a, b) => {
  if (a === '未发布' || b === '未发布') return a === '未发布' ? 1 : -1;
  return b.localeCompare(a);
});

---

<aside class="timeline-side">
  <div class="tl-head">
    <span class="ct"><T tkey="tags.postCount" params={{ count: posts.length }} /></span>
  </div>
  
  <div class="tl-rail">
    {yearMonths.map((yearMonth) => (
      <div class="tl-group" data-yearmonth={yearMonth}>
        <div class="tl-group-h">
          <span>
            {yearMonth === '未发布' ? (
              <T tkey="common.unpublished" />
            ) : (
              <T tkey="common.yearMonth" params={{ year: yearMonth.split('-')[0], month: yearMonth.split('-')[1] }} />
            )}
          </span>
          <span class="ct">({groupedPosts[yearMonth].length})</span>
        </div>
        
        <ul class="tl-list">
          {groupedPosts[yearMonth].map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class={`tl-item ${post.data.pinned ? 'pinned' : ''}`}>
                <span class="tl-d">
                  {post.data.pubDate ? (
                    <span data-i18n-date={post.data.pubDate.toISOString()} data-i18n-date-format="month-day">
                      {post.data.pubDate.toLocaleDateString(lang, { month: 'numeric', day: 'numeric' })}
                    </span>
                  ) : ''}
                </span>
                <span class="tl-t">{post.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</aside>

<style>
  .timeline-side {
    position: fixed;
    right: 0;
    top: 50%;
    width: 220px;
    transform: translateY(-50%);
    padding: 8px 28px 8px 0;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted);
    overflow-y: auto;
    max-height: calc(100vh - 144px);
    z-index: 10;
  }

  .tl-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 16px;
    white-space: nowrap;
  }

  .tl-head::before {
    content: "// timeline";
    color: var(--muted);
  }

  .tl-head .ct {
    color: var(--muted-2);
  }

  .tl-rail {
    position: relative;
    padding-left: 18px;
  }

  .tl-rail::before {
    content: "";
    position: absolute;
    left: 4px;
    top: 4px;
    bottom: 4px;
    width: 1px;
    background: var(--line);
  }

  .tl-group {
    margin-bottom: 22px;
  }

  .tl-group:last-child {
    margin-bottom: 0;
  }

  .tl-group-h {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 11px;
    color: var(--ink-2);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin: 0 0 10px -18px;
    padding-left: 18px;
    position: relative;
    white-space: nowrap;
  }

  .tl-group-h::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--bg);
    border: 1.5px solid var(--ink);
    box-sizing: border-box;
  }

  .tl-group-h .ct {
    color: var(--muted-2);
    font-weight: 400;
    font-size: 10.5px;
  }

  .tl-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tl-item {
    display: block;
    text-decoration: none;
    color: var(--muted);
    padding: 5px 0;
    position: relative;
    transition: color 0.12s;
    line-height: 1.45;
  }

  .tl-item::before {
    content: "";
    position: absolute;
    left: -18px;
    top: 12px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--muted-2);
    transition: background 0.15s, transform 0.15s;
  }

  .tl-item:hover {
    color: var(--ink);
  }

  .tl-item:hover::before {
    background: var(--accent);
    transform: scale(1.4);
  }

  .tl-item.active {
    color: var(--ink);
  }

  .tl-item.active::before {
    background: var(--accent);
  }

  .tl-d {
    color: var(--muted-2);
    font-size: 10.5px;
    display: block;
    margin-bottom: 1px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .tl-t {
    font-size: 11.5px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tl-item.pinned .tl-d::after {
    content: " 📌";
    color: var(--accent);
  }

  /* 移动端隐藏 */
  @media (max-width: 900px) {
    .timeline-side {
      display: none;
    }
  }
</style>
