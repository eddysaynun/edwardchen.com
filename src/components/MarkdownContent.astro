---
interface Props {
  html: string;
}

const { html } = Astro.props;

// Use unified to render markdown to HTML
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';

const processed = await unified()
  .use(remarkParse)
  .use(remarkRehype)
  .use(rehypeStringify)
  .process(html);
---

<div class="markdown-body" dangerouslySetInnerHTML={processed.result as any}></div>
