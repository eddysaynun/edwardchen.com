---
import { t, DEFAULT_LANG, translations } from '../utils/i18n';

interface Props {
  placeholder?: string;
}

const { placeholder = t('blog.searchPlaceholder', DEFAULT_LANG) } = Astro.props;
const searchTranslations = {
  resultsCount: translations['search.resultsCount'],
  noDescription: translations['search.noDescription'],
};
---

<div class="search">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8"></circle>
    <path d="m21 21-4.35-4.35"></path>
  </svg>
  <input 
    type="text" 
    id="search-input" 
    placeholder={placeholder}
    aria-label={t('blog.searchPlaceholder', DEFAULT_LANG)}
    data-i18n-placeholder="blog.searchPlaceholder"
    data-i18n-aria-label="blog.searchPlaceholder"
    autocomplete="off"
  />
  <span class="kchip">⏎</span>
  <button id="clear-search" class="clear" aria-label={t('search.clear', DEFAULT_LANG)} data-i18n-aria-label="search.clear">×</button>
</div>

<div id="search-results" class="search-results" hidden>
  <div class="results-header">
    <span class="results-count"></span>
  </div>
  <ul class="results-list"></ul>
</div>

<script define:vars={{ searchTranslations }}>
  let index = null;
  let data = [];
  let latestResults = [];
  let latestQuery = '';

  function getLang() {
    const lang = document.documentElement.dataset.lang || document.documentElement.lang;
    return lang === 'en' ? 'en' : 'zh-CN';
  }

  function translate(key, params = {}) {
    const template = searchTranslations[key]?.[getLang()] || key;
    return Object.entries(params).reduce(
      (text, [name, value]) => text.replace(`{${name}}`, String(value)),
      template
    );
  }
  
  async function loadIndex() {
    if (index) return;
    
    try {
      const response = await fetch('/search-index.json');
      if (!response.ok) throw new Error('Search index not found');
      data = await response.json();
      
      // Initialize FlexSearch
      index = new FlexSearch.Document({
        document: {
          id: 'id',
          index: ['title', 'description', 'content'],
          tag: 'tags'
        },
        tokenize: 'forward',
        context: {
          resolution: 9,
          depth: 2,
          separation: false
        }
      });
      
      // Add documents to index
      data.forEach(doc => index.add(doc));
    } catch (error) {
      console.error('Failed to load search index:', error);
    }
  }
  
  function highlightText(text, query) {
    if (!query) return text;
    const regex = new RegExp(`(${query})`, 'gi');
    return text.replace(regex, '<mark>$1</mark>');
  }
  
  function renderResults(results, query) {
    const resultsContainer = document.getElementById('search-results');
    const resultsList = resultsContainer.querySelector('.results-list');
    const resultsCount = resultsContainer.querySelector('.results-count');
    
    if (results.length === 0) {
      resultsContainer.hidden = true;
      return;
    }
    
    resultsContainer.hidden = false;
    resultsCount.textContent = translate('resultsCount', { count: results.length });
    
    resultsList.innerHTML = results.map(item => {
      const post = data[item.id];
      return `
        <li class="result-item">
          <a href="${post.slug}" class="result-link">
            <h3 class="result-title">${highlightText(post.title, query)}</h3>
            <p class="result-description">${highlightText(post.description || translate('noDescription'), query)}</p>
            <div class="result-meta">
              <time datetime="${post.published}">${new Date(post.published).toLocaleDateString(getLang())}</time>
              ${post.tags.length > 0 ? `<span class="result-tags">${post.tags.slice(0, 3).map(tag => `#${tag}`).join(' ')}</span>` : ''}
            </div>
          </a>
        </li>
      `;
    }).join('');
  }
  
  // Event listeners
  const searchInput = document.getElementById('search-input');
  const clearBtn = document.getElementById('clear-search');
  
  searchInput.addEventListener('input', async (e) => {
    const query = e.target.value.trim();
    
    if (!query) {
      document.getElementById('search-results').hidden = true;
      clearBtn.style.display = 'none';
      return;
    }
    
    clearBtn.style.display = 'grid';
    
    // Load index on first search
    if (!index) {
      await loadIndex();
    }
    
    // Search
    if (index) {
      const results = index.search(query, {
        limit: 10,
        suggest: true,
        enrichment: true
      }).flatMap(r => r.result);
      
      latestResults = results;
      latestQuery = query;
      renderResults(results, query);
    }
  });
  
  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    clearBtn.style.display = 'none';
    document.getElementById('search-results').hidden = true;
    searchInput.focus();
  });

  document.addEventListener('i18n:change', () => {
    if (latestResults.length > 0 && latestQuery) {
      renderResults(latestResults, latestQuery);
    }
  });
  
  // Close results when clicking outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.search-container') && !e.target.closest('.search-results')) {
      document.getElementById('search-results').hidden = true;
    }
  });
  
  // Load index on mount
  loadIndex();
</script>

<style>
  /* Search - matching Blog_writing.html */
  .search {
    position: relative;
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
  }
  
  .search svg {
    position: absolute;
    left: 10px;
    width: 12px;
    height: 12px;
    color: var(--muted-2);
    pointer-events: none;
  }
  
  .search input {
    width: 100%;
    appearance: none;
    outline: 0;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    border-radius: 6px;
    height: 30px;
    padding: 0 30px 0 28px;
    font: 12px/1 var(--mono);
    letter-spacing: -.005em;
    transition: border-color .15s, background .15s;
  }
  
  .search input::placeholder {
    color: var(--muted-2);
  }
  
  .search input:hover {
    border-color: var(--line-strong);
  }
  
  .search input:focus {
    border-color: var(--ink);
    background: var(--bg);
  }
  
  .search .kchip {
    position: absolute;
    right: 6px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted-2);
    padding: 2px 5px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--panel);
    pointer-events: none;
  }
  
  .search input:focus ~ .kchip {
    opacity: 0;
  }
  
  .search .clear {
    position: absolute;
    right: 6px;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 0;
    background: transparent;
    cursor: pointer;
    color: var(--muted-2);
    display: none;
    grid-template-rows: 1fr;
    font: 12px/1 var(--mono);
    place-items: center;
  }
  
  .search .clear:hover {
    color: var(--ink);
    background: var(--panel);
  }
  
  /* Search Results */
  .search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--bg);
    border: 1px solid var(--line-strong);
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    max-height: 500px;
    overflow-y: auto;
    z-index: 100;
  }
  
  .results-header {
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
    font-size: 11px;
    color: var(--muted);
    font-family: var(--mono);
  }
  
  .results-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .result-item {
    border-bottom: 1px solid var(--line);
  }
  
  .result-item:last-child {
    border-bottom: none;
  }
  
  .result-link {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  
  .result-link:hover {
    background: var(--panel);
  }
  
  .result-title {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 4px;
    color: var(--ink);
    line-height: 1.4;
  }
  
  .result-description {
    font-size: 13px;
    color: var(--muted);
    margin: 0 0 6px;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .result-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    color: var(--muted);
    font-family: var(--mono);
  }
  
  .result-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  
  mark {
    background: var(--accent-soft);
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }
</style>
