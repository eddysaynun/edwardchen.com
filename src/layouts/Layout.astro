---
import '../styles/global.css';
import '../styles/markdown.css';
import CopyCode from '../components/CopyCode.astro';
import Tweaks from '../components/Tweaks.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Edward Chen - 构建事物的笔记" } = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="wrap">
      <!-- Header -->
      <header class="site">
        <div class="site-inner">
          <a href="/" class="brand">
            <span class="glyph">~</span>
            <span>edward</span>
            <span class="cursor"></span>
          </a>
          
          <nav class="top">
            <a href="/" class={Astro.url.pathname === '/' || Astro.url.pathname === '/index.html' ? 'active' : ''}>首页</a>
            <a href="/blog" class={Astro.url.pathname === '/blog' || Astro.url.pathname.startsWith('/blog/') ? 'active' : ''}>文章</a>
            <a href="/tags" class={Astro.url.pathname === '/tags' || Astro.url.pathname.startsWith('/tags/') ? 'active' : ''}>标签</a>
            <a href="/projects" class={Astro.url.pathname === '/projects' || Astro.url.pathname.startsWith('/projects/') ? 'active' : ''}>项目</a>
            <a href="/about" class={Astro.url.pathname === '/about' || Astro.url.pathname.startsWith('/about/') ? 'active' : ''}>关于</a>
          </nav>
        </div>
      </header>

      <!-- Main Content -->
      <main>
        <slot />
      </main>

      <!-- Footer -->
      <footer class="site">
        <span>© 2026 Edward Chen</span>
        <div class="links">
          <a href="https://github.com/eddysaynun" target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405 1.02 0 2.04.135 3 .405 2.28-1.56 3.285-1.23 3.285-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener" aria-label="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="mailto:chenzijian@dipeak.com" aria-label="Email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </a>
          <a href="/rss.xml" target="_blank" rel="noopener" aria-label="RSS 订阅">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1"></circle>
            </svg>
          </a>
        </div>
      </footer>
    </div>

    <Tweaks />
    <CopyCode />
  </body>
</html>
