---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Edward Chen - 构建事物的笔记" } = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    
    <!-- Global Styles -->
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="wrap">
      <!-- Header -->
      <header class="site">
        <div class="site-inner">
          <a href="/" class="brand">
            <span class="glyph">~</span>
            <span>edward</span>
            <span class="cursor"></span>
          </a>
          
          <nav class="top">
            <a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>首页</a>
            <a href="/blog" class={Astro.url.pathname.startsWith('/blog') ? 'active' : ''}>文章</a>
            <a href="/projects" class={Astro.url.pathname === '/projects' ? 'active' : ''}>项目</a>
            <a href="/about" class={Astro.url.pathname === '/about' ? 'active' : ''}>关于</a>
          </nav>
        </div>
      </header>

      <!-- Main Content -->
      <main>
        <slot />
      </main>

      <!-- Footer -->
      <footer class="site">
        <span>© 2025 Edward Chen</span>
        <div class="links">
          <a href="https://github.com/eddysaynun" target="_blank" rel="noopener">GitHub</a>
          <a href="https://twitter.com" target="_blank" rel="noopener">Twitter</a>
          <a href="mailto:chenzijian@dipeak.com">Email</a>
        </div>
      </footer>
    </div>
  </body>
</html>
