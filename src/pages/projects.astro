---
import Layout from '../layouts/Layout.astro';

interface Project {
  name: string;
  description: string;
  status: 'active' | 'wip' | 'archive';
  tags: string[];
}

const projects: Project[] = [
  {
    name: 'Hermes Agent',
    description: '一个智能 AI 助手，支持多工具协作和自主任务执行',
    status: 'active',
    tags: ['TypeScript', 'AI']
  },
  {
    name: 'RAG Toolkit',
    description: '简化 RAG 应用的开发工具包，支持多种向量数据库',
    status: 'active',
    tags: ['Python', 'RAG']
  },
  {
    name: 'Personal Blog',
    description: '基于 Astro 构建的静态博客，支持 Markdown 和自动部署',
    status: 'wip',
    tags: ['Astro', 'Tailwind']
  },
  {
    name: 'CLI Tools',
    description: '一系列实用的命令行工具，用于日常开发任务',
    status: 'archive',
    tags: ['Rust', 'CLI']
  }
];

const statusConfig = {
  active: { color: 'bg-green-500', label: '活跃' },
  wip: { color: 'bg-amber-500', label: '开发中' },
  archive: { color: 'bg-stone-400', label: '归档' }
};
---

<Layout title="项目 - Edward 的博客">
  <section class="py-16 pb-10">
    <div class="flex items-center gap-2.5 font-mono text-[11.5px] text-stone-500 mb-5.5">
      <span>开源项目 · 实验作品 · 工具集</span>
    </div>
    
    <h1 class="font-sans text-[34px] leading-[1.18] tracking-tight font-semibold mb-4.5 text-stone-900">
      项目
    </h1>
    
    <p class="text-base text-stone-500 max-w-[56ch]">
      记录我的开源项目、实验性作品和工具集。
    </p>
  </section>

  <!-- Projects Grid -->
  <section class="pt-9 pb-7 border-t border-stone-200">
    <div class="grid grid-cols-2 gap-3">
      {projects.map((project) => {
        const status = statusConfig[project.status];
        return (
          <article class="border border-stone-200 rounded-[6px] p-4 bg-transparent flex flex-col gap-2 transition-[border-color,transform] hover:border-stone-300 relative overflow-hidden">
            <h4 class="m-0 text-sm font-semibold tracking-tight flex items-center gap-2">
              <span class={`w-1.75 h-1.75 rounded-full ${status.color}`} title={status.label}></span>
              {project.name}
            </h4>
            <p class="m-0 text-stone-500 text-[12.5px] leading-[1.5] flex-1">
              {project.description}
            </p>
            <div class="font-mono text-[10.5px] text-stone-400 flex gap-2.5 items-center border-t border-dashed border-stone-200 pt-2 mt-0.5">
              {project.tags.map((tag) => (
                <span><span class="text-orange-600 mr-1">■</span>{tag}</span>
              ))}
            </div>
          </article>
        );
      })}
    </div>
  </section>
</Layout>
