---
import Layout from '../layouts/Layout.astro';

interface Project {
  name: string;
  description: string;
  status: 'active' | 'wip' | 'archive';
  tags: string[];
}

const projects: Project[] = [
  {
    name: 'Hermes Agent',
    description: '一个智能 AI 助手，支持多工具协作和自主任务执行',
    status: 'active',
    tags: ['TypeScript', 'AI']
  },
  {
    name: 'RAG Toolkit',
    description: '简化 RAG 应用的开发工具包，支持多种向量数据库',
    status: 'active',
    tags: ['Python', 'RAG']
  },
  {
    name: 'Personal Blog',
    description: '基于 Astro 构建的静态博客，支持 Markdown 和自动部署',
    status: 'wip',
    tags: ['Astro', 'Tailwind']
  },
  {
    name: 'CLI Tools',
    description: '一系列实用的命令行工具，用于日常开发任务',
    status: 'archive',
    tags: ['Rust', 'CLI']
  }
];
---

<Layout title="项目 - Edward Chen">
  <section class="hero rise">
    <div class="meta">
      <span>开源项目 · 实验作品 · 工具集</span>
    </div>
    
    <h1>项目</h1>
    
    <p class="lede">记录我的开源项目、实验性作品和工具集。</p>
  </section>

  <!-- Projects Grid -->
  <section class="sec rise d1">
    <div class="projects">
      {projects.map((project) => (
        <article class="project">
          <h4>
            <span class={`stat ${project.status}`} title={project.status === 'active' ? '活跃' : project.status === 'wip' ? '开发中' : '归档'}></span>
            {project.name}
          </h4>
          <p>{project.description}</p>
          <div class="foot">
            {project.tags.map((tag) => (
              <span class="lang">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
