---
import Layout from '../layouts/Layout.astro';
import { t, getCurrentLang } from '../utils/i18n';

const lang = getCurrentLang(false);

interface Project {
  name: string;
  description: string;
  status: 'active' | 'wip' | 'archive';
  tags: string[];
}

const projects: Project[] = [
  {
    name: 'Hermes Agent',
    description: lang === 'zh-CN' 
      ? '一个智能 AI 助手，支持多工具协作和自主任务执行'
      : 'An intelligent AI assistant with multi-tool collaboration and autonomous task execution',
    status: 'active',
    tags: ['TypeScript', 'AI']
  },
  {
    name: 'RAG Toolkit',
    description: lang === 'zh-CN'
      ? '简化 RAG 应用的开发工具包，支持多种向量数据库'
      : 'A toolkit for simplifying RAG application development with multiple vector database support',
    status: 'active',
    tags: ['Python', 'RAG']
  },
  {
    name: 'Personal Blog',
    description: lang === 'zh-CN'
      ? '基于 Astro 构建的静态博客，支持 Markdown 和自动部署'
      : 'A static blog built with Astro, supporting Markdown and automatic deployment',
    status: 'wip',
    tags: ['Astro', 'Tailwind']
  },
  {
    name: 'CLI Tools',
    description: lang === 'zh-CN'
      ? '一系列实用的命令行工具，用于日常开发任务'
      : 'A collection of practical CLI tools for daily development tasks',
    status: 'archive',
    tags: ['Rust', 'CLI']
  }
];
---

<Layout title={t('projects.title', lang)}>
  <section class="hero rise">
    <div class="meta">
      <span>{t('projects.meta', lang)}</span>
    </div>
    
    <h1>{t('nav.projects', lang)}</h1>
    
    <p class="lede">{t('projects.lede', lang)}</p>
  </section>

  <!-- Projects Grid -->
  <section class="sec rise d1">
    <div class="projects">
      {projects.map((project) => (
        <article class="project">
          <h4>
            <span class={`stat ${project.status}`} title={
              project.status === 'active' ? t('projects.status.active', lang) : 
              project.status === 'wip' ? t('projects.status.wip', lang) : 
              t('projects.status.archive', lang)
            }></span>
            {project.name}
          </h4>
          <p>{project.description}</p>
          <div class="foot">
            {project.tags.map((tag) => (
              <span class="lang">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
