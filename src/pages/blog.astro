---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 获取所有博客文章
const allPosts = await getCollection('blog');

// 按日期排序
const posts = allPosts.sort((a, b) => {
  const dateA = a.data.pubDate || new Date(0);
  const dateB = b.data.pubDate || new Date(0);
  return dateB.getTime() - dateA.getTime();
});

// 提取所有标签
const tagCounts: Record<string, number> = {};
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const allTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
---

<Layout title="文章 - Edward Chen">
  <section class="hero rise">
    <div class="meta">
      <span>技术笔记 · 学习记录 · 项目经验</span>
    </div>
    
    <h1>文章</h1>
    
    <p class="lede">记录技术探索、项目经验和学习心得。</p>
  </section>

  <!-- Tags Filter -->
  <section class="sec rise d1">
    <div class="tags">
      <button class="tag on">
        全部
        <span class="ct">({posts.length})</span>
      </button>
      {allTags.map((tag) => (
        <button class="tag">
          {tag}
          <span class="ct">({tagCounts[tag]})</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Posts List -->
  <section class="sec rise d2">
    <ol class="posts">
      {posts.map((post) => (
        <li class={`post ${post.data.pinned ? 'pinned' : ''}`}>
          <time class="date" datetime={post.data.pubDate?.toISOString() || ''}>
            {post.data.pubDate?.toLocaleDateString('zh-CN') || '未发布'}
          </time>
          <div class="body">
            <h3>
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="row">
              {post.data.tags.map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          </div>
          <div class="meta-r">
            <span class="arrow">→</span>
          </div>
        </li>
      ))}
    </ol>
  </section>
</Layout>
