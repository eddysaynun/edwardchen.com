---
import Layout from '../layouts/Layout.astro';

interface BlogPost {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
}

const posts: BlogPost[] = [
  {
    slug: 'astro-blog-setup',
    title: '从零搭建 Astro 个人博客',
    description: '使用 Astro + TailwindCSS 构建一个现代化的静态博客，支持 Markdown 写作和自动部署。',
    date: '2025-05-10',
    tags: ['Astro', '博客', '静态站点']
  },
  {
    slug: 'ai-agent-workflow',
    title: 'AI Agent 工作流实践',
    description: '探索如何使用 AI Agent 自动化日常开发任务，提升工作效率。',
    date: '2025-05-08',
    tags: ['AI', '自动化', '生产力']
  },
  {
    slug: 'docker-k8s-notes',
    title: 'Docker 和 K8s 学习笔记',
    description: '整理容器化和 Kubernetes 的核心概念与最佳实践。',
    date: '2025-05-01',
    tags: ['Docker', 'Kubernetes', 'DevOps']
  },
  {
    slug: 'rag-fundamentals',
    title: 'RAG 技术原理解析',
    description: '深入理解检索增强生成的工作原理和实现细节。',
    date: '2025-04-25',
    tags: ['RAG', 'AI', '向量数据库']
  },
  {
    slug: 'typescript-best-practices',
    title: 'TypeScript 最佳实践',
    description: '分享在大型项目中使用 TypeScript 的经验与技巧。',
    date: '2025-04-18',
    tags: ['TypeScript', '前端', '最佳实践']
  }
];

const allTags = Array.from(new Set(posts.flatMap(p => p.tags))).sort();
---

<Layout title="文章 - Edward Chen">
  <section class="hero rise">
    <div class="meta">
      <span>技术笔记 · 学习记录 · 项目经验</span>
    </div>
    
    <h1>文章</h1>
    
    <p class="lede">记录技术探索、项目经验和学习心得。</p>
  </section>

  <!-- Tags Filter -->
  <section class="sec rise d1">
    <div class="tags">
      <button class="tag on">
        全部
        <span class="ct">({posts.length})</span>
      </button>
      {allTags.map((tag) => {
        const count = posts.filter(p => p.tags.includes(tag)).length;
        return (
          <button class="tag">
            {tag}
            <span class="ct">({count})</span>
          </button>
        );
      })}
    </div>
  </section>

  <!-- Posts List -->
  <section class="sec rise d2">
    <ol class="posts">
      {posts.map((post) => (
        <li class="post">
          <time class="date" datetime={post.date}>{post.date}</time>
          <div class="body">
            <h3>
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h3>
            <p>{post.description}</p>
            <div class="row">
              {post.tags.map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          </div>
          <div class="meta-r">
            <span class="arrow">→</span>
          </div>
        </li>
      ))}
    </ol>
  </section>
</Layout>
