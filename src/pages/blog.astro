---
import Layout from '../layouts/Layout.astro';
import T from '../components/T.astro';
import { getCollection } from 'astro:content';
import { sortPostsByPinnedAndDate } from '../utils/posts';
import Timeline from '../components/Timeline.astro';
import Search from '../components/Search.astro';
import { t, DEFAULT_LANG } from '../utils/i18n';

const lang = DEFAULT_LANG;

// 获取所有博客文章
const allPosts = await getCollection('blog');

// 使用工具函数排序
const posts = sortPostsByPinnedAndDate(allPosts);

// 提取所有标签
const tagCounts: Record<string, number> = {};
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const allTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
---

<Layout title={t('blog.title', lang)}>
  <section class="hero rise">
    <div class="meta">
      <T tkey="blog.meta" />
    </div>

    <h1><T tkey="nav.blog" /></h1>

    <p class="lede"><T tkey="blog.lede" /></p>
  </section>

  <!-- Posts List with Search and Tags -->
  <section class="sec rise d2">
    <div class="sec-head">
      <h2>文章列表</h2>
      <span class="aux">{posts.length} 篇文章</span>
    </div>
    
    <!-- Controls: Search + Tags -->
    <div class="controls">
      <Search placeholder={t('blog.searchPlaceholder', lang)} />
    </div>
    
    <div class="tags-wrapper">
      <div class="tags">
        <button class="tag active" data-tag="all">
          <T tkey="blog.all" />
          <span class="ct">({posts.length})</span>
        </button>
        {allTags.map((tag, index) => (
          <button class={`tag${index >= 10 ? ' hidden-tag' : ''}`} data-tag={tag}>
            {tag}
            <span class="ct">({tagCounts[tag]})</span>
          </button>
        ))}
      </div>
      {allTags.length > 10 && (
        <button id="toggle-tags" type="button" class="toggle-tags-btn">
          <span class="show-text">展开 {allTags.length - 10} 个标签</span>
          <span class="hide-text" style="display: none;">收起</span>
        </button>
      )}
    </div>
    
    <ol class="posts" id="posts-list">
      {posts.map((post) => (
        <li class={`post ${post.data.pinned ? 'pinned' : ''}`} data-tags={post.data.tags.join(',')}>
          <time class="date" datetime={post.data.pubDate?.toISOString() || ''}>
            {post.data.pubDate?.toLocaleDateString(lang) || t('common.unpublished', lang)}
          </time>
          <div class="body">
            <h3>
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="row">
              {post.data.tags.map((tag) => (
                <a href={`/blog?tag=${encodeURIComponent(tag)}`} 
                   class="pill"
                   aria-label={`查看 ${tag} 标签的文章`}>
                  {tag}
                </a>
              ))}
            </div>
          </div>
          <div class="meta-r">
            <span class="arrow">→</span>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Timeline Sidebar -->
  <Timeline posts={posts} />

  <script is:inline>
    (function() {
      const tagButtons = document.querySelectorAll('.tag');
      const posts = document.querySelectorAll('#posts-list .post');
      const urlParams = new URLSearchParams(window.location.search);
      const selectedTag = urlParams.get('tag');

      // 高亮选中的 tag 按钮
      if (selectedTag) {
        tagButtons.forEach(btn => {
          btn.classList.toggle('on', btn.dataset.tag === selectedTag);
        });
        filterPosts(selectedTag);
      } else {
        tagButtons[0]?.classList.add('on');
      }

      // 点击 tag 按钮筛选
      tagButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tag = btn.dataset.tag;
          
          // 更新按钮状态
          tagButtons.forEach(b => b.classList.remove('on'));
          btn.classList.add('on');

          // 更新 URL（不刷新页面）
          const newUrl = tag === 'all' 
            ? '/blog' 
            : '/blog?tag=' + encodeURIComponent(tag);
          history.pushState({ tag: tag }, '', newUrl);

          // 筛选文章
          filterPosts(tag);
        });
      });

      // 筛选函数
      function filterPosts(tag) {
        posts.forEach(post => {
          const postTags = post.dataset.tags.split(',');
          if (tag === 'all' || postTags.includes(tag)) {
            post.style.display = '';
          } else {
            post.style.display = 'none';
          }
        });
      }

      // 支持浏览器前进后退
      window.addEventListener('popstate', function(e) {
        var tag = (e.state && e.state.tag) || 'all';
        tagButtons.forEach(function(btn) {
          btn.classList.toggle('on', btn.dataset.tag === tag);
        });
        filterPosts(tag);
      });
    })();
  </script>

  <style>
    /* Controls row */
    .controls {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    /* Tags toggle */
    .tags-wrapper {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 18px;
    }

    .hidden-tag {
      display: none;
    }

    .toggle-tags-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
      color: var(--muted, #666);
      transition: color 0.2s;
      text-align: left;
    }

    .toggle-tags-btn:hover {
      color: var(--ink, #333);
    }
  </style>

  <script is:inline>
    (function() {
      const toggle = document.getElementById('toggle-tags');
      const tagsContainer = document.querySelector('.tags');
      if (!toggle || !tagsContainer) return;
      const showText = toggle.querySelector('.show-text');
      const hideText = toggle.querySelector('.hide-text');

      toggle.addEventListener('click', () => {
        const hidden = tagsContainer.querySelectorAll('.hidden-tag');
        if (hidden.length > 0) {
          hidden.forEach(t => t.classList.remove('hidden-tag'));
          if (showText) showText.style.display = 'none';
          if (hideText) hideText.style.display = '';
        } else {
          tagsContainer.querySelectorAll('.tag').forEach((t, i) => {
            if (i >= 10) t.classList.add('hidden-tag');
          });
          if (showText) showText.style.display = '';
          if (hideText) hideText.style.display = 'none';
        }
      });
    })();
  </script>
</Layout>
