---
import Layout from '../layouts/Layout.astro';
---

<Layout title="~/edward — 构建事物的笔记">
  <!-- Hero Section -->
  <section class="hero rise">
    <div class="meta">
      <span class="dot"></span>
      <span>个人开发者 · AI 爱好者 · 技术写作者</span>
    </div>
    
    <h1>
      你好，我是 <em>Edward</em>
      <span class="mono">v2.0</span>
    </h1>
    
    <p class="lede">
      我喜欢构建有趣的东西，探索 AI 的可能性，并分享我的学习旅程。这里是我的技术笔记、项目展示和思考记录。
    </p>
    
    <div class="links">
      <a href="/blog">
        阅读文章
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/projects">
        查看项目
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://github.com/eddysaynun" target="_blank" rel="noopener">
        GitHub
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M6.5 2.5V6.5M6.5 6.5L4 4M6.5 6.5L9 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="sec rise d1">
    <div class="sec-head">
      <h2>最新文章</h2>
      <span class="aux"><a href="/blog">查看全部 →</a></span>
    </div>

    <ol class="posts">
      <!-- Post 1 -->
      <li class="post">
        <time class="date" datetime="2025-05-10">2025-05-10</time>
        <div class="body">
          <h3>
            <a href="/blog/astro-blog-setup">从零搭建 Astro 个人博客</a>
          </h3>
          <p>使用 Astro + TailwindCSS 构建一个现代化的静态博客，支持 Markdown 写作和自动部署。</p>
          <div class="row">
            <span class="pill">Astro</span>
            <span class="pill">博客</span>
          </div>
        </div>
        <div class="meta-r">
          <span class="arrow">→</span>
        </div>
      </li>

      <!-- Post 2 -->
      <li class="post">
        <time class="date" datetime="2025-05-08">2025-05-08</time>
        <div class="body">
          <h3>
            <a href="/blog/ai-agent-workflow">AI Agent 工作流实践</a>
          </h3>
          <p>探索如何使用 AI Agent 自动化日常开发任务，提升工作效率。</p>
          <div class="row">
            <span class="pill">AI</span>
            <span class="pill">自动化</span>
          </div>
        </div>
        <div class="meta-r">
          <span class="arrow">→</span>
        </div>
      </li>

      <!-- Post 3 -->
      <li class="post">
        <time class="date" datetime="2025-05-01">2025-05-01</time>
        <div class="body">
          <h3>
            <a href="/blog/docker-k8s-notes">Docker 和 K8s 学习笔记</a>
          </h3>
          <p>整理容器化和 Kubernetes 的核心概念与最佳实践。</p>
          <div class="row">
            <span class="pill">Docker</span>
            <span class="pill">K8s</span>
          </div>
        </div>
        <div class="meta-r">
          <span class="arrow">→</span>
        </div>
      </li>
    </ol>
  </section>

  <!-- Projects -->
  <section class="sec rise d2">
    <div class="sec-head">
      <h2>项目</h2>
      <span class="aux"><a href="/projects">查看全部 →</a></span>
    </div>

    <div class="projects">
      <!-- Project 1 -->
      <article class="project">
        <h4>
          <span class="stat active" title="活跃"></span>
          Hermes Agent
        </h4>
        <p>一个智能 AI 助手，支持多工具协作和自主任务执行。</p>
        <div class="foot">
          <span class="lang">TypeScript</span>
          <span class="lang">AI</span>
        </div>
      </article>

      <!-- Project 2 -->
      <article class="project">
        <h4>
          <span class="stat active" title="活跃"></span>
          RAG Toolkit
        </h4>
        <p>简化 RAG 应用的开发工具包，支持多种向量数据库。</p>
        <div class="foot">
          <span class="lang">Python</span>
          <span class="lang">RAG</span>
        </div>
      </article>

      <!-- Project 3 -->
      <article class="project">
        <h4>
          <span class="stat wip" title="开发中"></span>
          Personal Blog
        </h4>
        <p>基于 Astro 构建的静态博客，支持 Markdown 和自动部署。</p>
        <div class="foot">
          <span class="lang">Astro</span>
          <span class="lang">Tailwind</span>
        </div>
      </article>

      <!-- Project 4 -->
      <article class="project">
        <h4>
          <span class="stat archive" title="归档"></span>
          CLI Tools
        </h4>
        <p>一系列实用的命令行工具，用于日常开发任务。</p>
        <div class="foot">
          <span class="lang">Rust</span>
          <span class="lang">CLI</span>
        </div>
      </article>
    </div>
  </section>

  <!-- Now Page -->
  <section class="sec rise d3">
    <div class="sec-head">
      <h2>正在进行</h2>
    </div>

    <div class="now">
      <time class="stamp">2025.05</time>
      <ul>
        <li>
          <span class="b">1</span>
          <span class="t">完成个人博客的基础搭建</span>
        </li>
        <li>
          <span class="b">2</span>
          <span class="t">学习 Astro 的内容集合功能</span>
        </li>
        <li>
          <span class="b">3</span>
          <span class="t">部署到 Cloudflare Pages</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">研究最佳博客方案</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">完善页面渲染设计</span>
        </li>
      </ul>
    </div>
  </section>
</Layout>
