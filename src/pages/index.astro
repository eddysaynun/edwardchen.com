---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { sortPostsByPinnedAndDate } from '../utils/posts';
import { t, getCurrentLang } from '../utils/i18n';

const lang = getCurrentLang(false);

// 获取所有博客文章
const allPostsRaw = await getCollection('blog');

// 使用工具函数排序
const allPosts = sortPostsByPinnedAndDate(allPostsRaw);

// 获取最新的 3 篇文章（优先展示置顶）
const latestPosts = allPosts.slice(0, 3);
---

<Layout title="~/edward — 构建事物的笔记">
  <!-- Hero Section -->
  <section class="hero rise">
    <div class="meta">
      <span class="dot"></span>
      <span>{t('home.meta', lang)}</span>
    </div>
    
    <h1>
      {t('home.greeting', lang)} <em>Edward</em>
    </h1>
    
    <p class="lede">
      {t('home.lede', lang)}
    </p>
    
    <div class="links">
      <a href="/blog">
        {t('home.readPosts', lang)}
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/projects">
        {t('home.viewProjects', lang)}
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://github.com/eddysaynun" target="_blank" rel="noopener">
        GitHub
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="sec rise d1">
    <div class="sec-head">
      <h2>{t('home.latestPosts', lang)}</h2>
      <span class="aux"><a href="/blog">{t('home.viewAll', lang)}</a></span>
    </div>

    <ol class="posts">
      {latestPosts.map((post) => (
        <li class={`post ${post.data.pinned ? 'pinned' : ''}`}>
          <time class="date" datetime={post.data.pubDate?.toISOString() || ''}>
            {post.data.pubDate?.toLocaleDateString(lang)}
          </time>
          <div class="body">
            <h3>
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="row">
              {post.data.tags.map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          </div>
          <div class="meta-r">
            <span class="arrow">→</span>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Projects -->
  <section class="sec rise d2">
    <div class="sec-head">
      <h2>{t('home.projects', lang)}</h2>
      <span class="aux"><a href="/projects">{t('home.viewAll', lang)}</a></span>
    </div>

    <div class="projects">
      <!-- Project 1 -->
      <article class="project">
        <h4>
          <span class="stat active" title={t('projects.active', lang)}></span>
          Hermes Agent
        </h4>
        <p>一个智能 AI 助手，支持多工具协作和自主任务执行。</p>
        <div class="foot">
          <span class="lang">TypeScript</span>
          <span class="lang">AI</span>
        </div>
      </article>

      <!-- Project 2 -->
      <article class="project">
        <h4>
          <span class="stat active" title={t('projects.active', lang)}></span>
          RAG Toolkit
        </h4>
        <p>简化 RAG 应用的开发工具包，支持多种向量数据库。</p>
        <div class="foot">
          <span class="lang">Python</span>
          <span class="lang">RAG</span>
        </div>
      </article>

      <!-- Project 3 -->
      <article class="project">
        <h4>
          <span class="stat wip" title={t('projects.wip', lang)}></span>
          Personal Blog
        </h4>
        <p>基于 Astro 构建的静态博客，支持 Markdown 和自动部署。</p>
        <div class="foot">
          <span class="lang">Astro</span>
          <span class="lang">Tailwind</span>
        </div>
      </article>

      <!-- Project 4 -->
      <article class="project">
        <h4>
          <span class="stat archive" title={t('projects.archive', lang)}></span>
          CLI Tools
        </h4>
        <p>一系列实用的命令行工具，用于日常开发任务。</p>
        <div class="foot">
          <span class="lang">Rust</span>
          <span class="lang">CLI</span>
        </div>
      </article>
    </div>
  </section>

  <!-- Now Page -->
  <section class="sec rise d3">
    <div class="sec-head">
      <h2>{t('home.now', lang)}</h2>
    </div>

    <div class="now">
      <time class="stamp">2026.05</time>
      <ul>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">完成个人博客的基础搭建</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">实现 Markdown 内容集合</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">部署到 Cloudflare Pages</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">研究最佳博客方案</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">完善页面渲染设计</span>
        </li>
        <li class="done">
          <span class="b">✓</span>
          <span class="t">添加自定义设置面板</span>
        </li>
      </ul>
    </div>
  </section>
</Layout>
