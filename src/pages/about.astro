---
import Layout from '../layouts/Layout.astro';
import { t, getCurrentLang } from '../utils/i18n';

const lang = getCurrentLang(false);
---

<Layout title={t('about.title', lang)}>
  <section class="hero rise">
    <div class="meta">
      <span>{t('about.meta', lang)}</span>
    </div>
    
    <h1>{t('nav.about', lang)}</h1>
  </section>

  <section class="sec rise d1">
    <div class="prose max-w-none">
      <p class="text-muted text-base leading-relaxed">
        {t('about.intro1', lang)}
      </p>
      
      <p class="text-muted text-base leading-relaxed">
        {t('about.intro2', lang)}
      </p>

      <div class="mt-8">
        <h2 class="font-mono text-xs font-medium text-muted tracking-wide mb-4">// {t('about.techStack', lang)}</h2>
        <div class="flex flex-wrap gap-2">
          <span class="pill">Java</span>
          <span class="pill">Python</span>
          <span class="pill">Astro</span>
          <span class="pill">Linux</span>
          <span class="pill">Docker</span>
          <span class="pill">Kubernetes</span>
          <span class="pill">AI/ML</span>
        </div>
      </div>

      <div class="mt-8">
        <h2 class="font-mono text-xs font-medium text-muted tracking-wide mb-4">// {t('about.contact', lang)}</h2>
        <div class="links">
          <a href="https://github.com/eddysaynun" target="_blank" rel="noopener">GitHub</a>
          <a href="https://x.com/eddysaynun" target="_blank" rel="noopener">Twitter</a>
          <a href="mailto:edward4run@outlook.com">Email</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
