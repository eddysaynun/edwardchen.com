---
import Layout from '../layouts/Layout.astro';
import { t, getCurrentLang } from '../utils/i18n';

const lang = getCurrentLang(false);
---

<Layout title={t('about.title', lang)}>
  <section class="hero rise">
    <div class="meta">
      <span>{t('about.meta', lang)}</span>
    </div>
    
    <h1>{t('nav.about', lang)}</h1>
  </section>

  <section class="sec rise d1">
    <div class="prose max-w-none">
      <p class="text-muted text-base leading-relaxed">
        {t('about.intro1', lang)}
      </p>
      
      <p class="text-muted text-base leading-relaxed">
        {t('about.intro2', lang)}
      </p>

      <div class="mt-8">
        <h2 class="font-mono text-xs font-medium text-muted tracking-wide mb-4">// {t('about.techStack', lang)}</h2>
        <div class="flex flex-wrap gap-2">
          <span class="pill">Java</span>
          <span class="pill">Python</span>
          <span class="pill">Astro</span>
          <span class="pill">Linux</span>
          <span class="pill">Docker</span>
          <span class="pill">Kubernetes</span>
          <span class="pill">AI/ML</span>
        </div>
      </div>

      <div class="mt-8">
        <h2 class="font-mono text-xs font-medium text-muted tracking-wide mb-4">// {t('about.contact', lang)}</h2>
        <div class="links" style="display: flex; gap: 16px; flex-wrap: wrap;">
          <a href="https://github.com/eddysaynun" target="_blank" rel="noopener" aria-label="GitHub" style="display: inline-flex; align-items: center; gap: 6px; color: var(--muted); text-decoration: none; transition: color 0.2s; font-size: 0.875rem; white-space: nowrap;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink: 0;">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405 1.02 0 2.04.135 3 .405 2.28-1.56 3.285-1.23 3.285-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span>GitHub</span>
          </a>
          <a href="https://x.com/eddysaynun" target="_blank" rel="noopener" aria-label="Twitter" style="display: inline-flex; align-items: center; gap: 6px; color: var(--muted); text-decoration: none; transition: color 0.2s; font-size: 0.875rem; white-space: nowrap;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink: 0;">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>Twitter</span>
          </a>
          <a href="mailto:edward4run@outlook.com" aria-label="Email" style="display: inline-flex; align-items: center; gap: 6px; color: var(--muted); text-decoration: none; transition: color 0.2s; font-size: 0.875rem; white-space: nowrap;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>Email</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
