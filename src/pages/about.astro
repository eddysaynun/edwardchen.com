---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于 - Edward Chen">
  <section class="hero rise">
    <div class="meta">
      <span>关于我</span>
    </div>
    
    <h1>关于</h1>
  </section>

  <section class="sec rise d1">
    <div class="prose max-w-none">
      <p class="text-muted text-base leading-relaxed">
        你好！我是 Edward Chen，一名个人开发者、AI 爱好者和技术写作者。
      </p>
      
      <p class="text-muted text-base leading-relaxed">
        我喜欢构建有趣的东西，探索人工智能的可能性，并分享我的学习旅程。这个博客是我记录技术笔记、项目展示和思考的地方。
      </p>

      <div class="mt-8">
        <h2 class="font-mono text-xs font-medium text-muted tracking-wide mb-4">// 技术栈</h2>
        <div class="flex flex-wrap gap-2">
          <span class="pill">TypeScript</span>
          <span class="pill">Python</span>
          <span class="pill">Rust</span>
          <span class="pill">Astro</span>
          <span class="pill">Docker</span>
          <span class="pill">Kubernetes</span>
          <span class="pill">AI/ML</span>
        </div>
      </div>

      <div class="mt-8">
        <h2 class="font-mono text-xs font-medium text-muted tracking-wide mb-4">// 联系方式</h2>
        <div class="links">
          <a href="https://github.com/eddysaynun" target="_blank" rel="noopener">GitHub</a>
          <a href="https://twitter.com" target="_blank" rel="noopener">Twitter</a>
          <a href="mailto:chenzijian@dipeak.com">Email</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
