---
import Layout from '../layouts/Layout.astro';

export interface BlogPost {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
}

const post: BlogPost = {
  slug: 'astro-blog-setup',
  title: '从零搭建 Astro 个人博客',
  description: '使用 Astro + TailwindCSS 构建一个现代化的静态博客，支持 Markdown 写作和自动部署。',
  date: '2025-05-10',
  tags: ['Astro', '博客', '静态站点']
};
---

<Layout title={`${post.title} - Edward 的博客`}>
  <article class="py-16">
    <!-- Post Header -->
    <header class="mb-10">
      <div class="flex items-center gap-2.5 font-mono text-[11.5px] text-stone-500 mb-5.5">
        <time datetime={post.date}>{post.date}</time>
        <span>•</span>
        <span>5 分钟阅读</span>
      </div>
      
      <h1 class="font-sans text-[34px] leading-[1.18] tracking-tight font-semibold mb-4.5 text-stone-900">
        {post.title}
      </h1>
      
      <p class="text-base text-stone-500 max-w-[56ch] mb-6">
        {post.description}
      </p>
      
      <div class="flex items-center gap-2.5 font-mono text-[11px] text-stone-400">
        {post.tags.map((tag) => (
          <span class="text-stone-500 border border-stone-200 px-1.5 rounded text-[10px]">{tag}</span>
        ))}
      </div>
    </header>

    <div class="pt-9 border-t border-stone-200 prose prose-stone max-w-none">
      <p>
        本文将介绍如何使用 Astro 和 TailwindCSS 从零搭建一个现代化的个人博客。
      </p>

      <h2 class="font-mono text-sm font-medium text-stone-900 mt-6 mb-3">// 为什么选择 Astro？</h2>
      <p>
        Astro 是一个现代的 Web 框架，专为内容驱动的网站设计。它的主要优势包括：
      </p>
      <ul class="list-disc list-inside space-y-2 text-stone-700">
        <li>极致的性能 — 默认零 JavaScript 输出</li>
        <li>优秀的 SEO — 静态生成支持</li>
        <li>灵活的框架支持 — 可以使用 React、Vue、Svelte 组件</li>
        <li>Markdown 原生支持 — 内容写作体验极佳</li>
      </ul>

      <h2 class="font-mono text-sm font-medium text-stone-900 mt-6 mb-3">// 项目初始化</h2>
      <p>首先，我们需要创建一个新的 Astro 项目：</p>
      
      <pre class="bg-stone-100 p-4 rounded-lg overflow-x-auto"><code class="font-mono text-sm">npm create astro@latest
# 或者
npx create-astro@latest</code></pre>

      <h2 class="font-mono text-sm font-medium text-stone-900 mt-6 mb-3">// 安装 TailwindCSS</h2>
      <p>
        使用 Astro 的官方 Tailwind 集成：
      </p>
      <pre class="bg-stone-100 p-4 rounded-lg overflow-x-auto"><code class="font-mono text-sm">npm install -D @astrojs/tailwind tailwindcss</code></pre>

      <h2 class="font-mono text-sm font-medium text-stone-900 mt-6 mb-3">// 创建内容集合</h2>
      <p>
        Astro 的内容集合功能让我们可以类型安全地管理博客文章。在 <code class="font-mono bg-stone-100 px-1.5 py-0.5 rounded">src/content</code> 目录下创建配置：
      </p>

      <h2 class="font-mono text-sm font-medium text-stone-900 mt-6 mb-3">// 部署到 Cloudflare Pages</h2>
      <p>
        构建项目并部署：
      </p>
      <pre class="bg-stone-100 p-4 rounded-lg overflow-x-auto"><code class="font-mono text-sm">npm run build</code></pre>
      <p>
        然后将 <code class="font-mono bg-stone-100 px-1.5 py-0.5 rounded">dist</code> 目录部署到 Cloudflare Pages 即可。
      </p>

      <h2 class="font-mono text-sm font-medium text-stone-900 mt-6 mb-3">// 总结</h2>
      <p>
        使用 Astro + TailwindCSS + Cloudflare Pages 是一个成本极低、性能优秀、易于维护的博客方案。适合个人开发者和技术写作者。
      </p>
    </div>

    <!-- Navigation -->
    <nav class="pt-9 mt-10 border-t border-stone-200 flex justify-between">
      <a href="/blog" class="font-mono text-[12px] text-stone-500 hover:text-stone-900 transition-colors inline-flex items-center gap-2">
        ← 返回文章列表
      </a>
      <a href="/blog/ai-agent-workflow" class="font-mono text-[12px] text-stone-500 hover:text-stone-900 transition-colors inline-flex items-center gap-2">
        下一篇：AI Agent 工作流实践 →
      </a>
    </nav>
  </article>
</Layout>
