---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';
import remarkGfm from 'remark-gfm';
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';

// 获取 URL 参数中的 id
const id = Astro.url.searchParams.get('id');

// 文章数据
let postContent = null;
let postData = null;

if (id) {
  // 动态读取 md 文件
  const blogDir = path.join(process.cwd(), 'src', 'content', 'blog');
  const filePath = path.join(blogDir, `${id}.md`);
  
  if (fs.existsSync(filePath)) {
    const fileContent = fs.readFileSync(filePath, 'utf-8');
    const { data, content } = matter(fileContent);
    
    postData = data;
    postContent = content;
  }
}

// 获取所有文章用于相关文章和导航
const allPosts = await getCollection('blog');

// 相关文章（基于标签匹配）
const relatedPosts = postData
  ? allPosts
      .filter(p => {
        if (p.slug === id) return false;
        return p.data.tags.some(tag => postData.tags?.includes(tag));
      })
      .slice(0, 3)
  : [];

// 排序用于上一篇/下一篇
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.pubDate || new Date(0);
  const dateB = b.data.pubDate || new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const postIndex = postData ? sortedPosts.findIndex(p => p.slug === id) : -1;
const prevPost = postIndex >= 0 ? sortedPosts[postIndex + 1] : null;
const nextPost = postIndex >= 0 ? sortedPosts[postIndex - 1] : null;

// 渲染 markdown
let htmlContent = '';
if (postContent) {
  const markdownHtml = await unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkRehype)
    .use(rehypeStringify)
    .process(postContent);
  
  htmlContent = markdownHtml.value?.toString() || '';
}
---

<Layout title={`${postData?.title || '文章'} - Edward Chen`}>
  {postData && postContent ? (
    <article class="rise">
      <header class="hero">
        <div class="meta">
          <time datetime={postData.pubDate?.toISOString() || ''}>
            {postData.pubDate?.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }) || '未发布'}
          </time>
          <span>•</span>
          <span>约 {Math.max(1, Math.ceil(postContent.length / 500))} 分钟阅读</span>
          {postData.pinned && (
            <>
              <span>•</span>
              <span class="text-accent font-medium">置顶</span>
            </>
          )}
        </div>
        
        <h1>{postData.title}</h1>
        <p class="lede mb-6">{postData.description}</p>
        
        <div class="row gap-2 flex-wrap">
          {postData.tags?.map((tag) => (
            <a href={`/blog?id=${id}&tag=${encodeURIComponent(tag)}`} 
               class="pill text-xs text-stone-600 bg-stone-100 hover:bg-stone-200 hover:text-stone-900 transition-colors px-3 py-1"
               aria-label={`查看 ${tag} 标签的文章`}>
              #{tag}
            </a>
          ))}
        </div>
      </header>

      <section class="sec">
        <div class="markdown-body">
          <div set:html={htmlContent}></div>
        </div>
      </section>

      {relatedPosts.length > 0 && (
        <section class="sec">
          <div class="sec-head">
            <h2>相关文章</h2>
          </div>
          <div class="projects">
            {relatedPosts.map((relatedPost) => (
              <article class="project">
                <h4>
                  <a href={`/blog?id=${relatedPost.slug}`}>{relatedPost.data.title}</a>
                </h4>
                <p>{relatedPost.data.description}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <nav class="sec flex justify-between items-center flex-wrap gap-4">
        {prevPost ? (
          <a href={`/blog?id=${prevPost.slug}`} class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
            ← 上一篇：{prevPost.data.title}
          </a>
        ) : (
          <a href="/blog" class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
            ← 返回文章列表
          </a>
        )}
        
        {nextPost && (
          <a href={`/blog?id=${nextPost.slug}`} class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
            下一篇：{nextPost.data.title} →
          </a>
        )}
      </nav>
    </article>
  ) : (
    <article class="rise">
      <header class="hero">
        <h1>文章未找到</h1>
        <p class="lede">抱歉，你访问的文章不存在或已被删除。</p>
      </header>
      <section class="sec">
        <a href="/blog" class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          ← 返回文章列表
        </a>
      </section>
    </article>
  )}
</Layout>
