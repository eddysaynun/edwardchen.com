---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';
import remarkGfm from 'remark-gfm';
import { toString } from 'mdast-util-to-string';
import Giscus from '../../components/Giscus.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { t, getCurrentLang } from '../../utils/i18n';

const lang = getCurrentLang(false);

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = (await getCollection('blog')).find(p => p.slug === slug);

if (!post) {
  Astro.redirect('/blog');
}

// 使用工具函数获取相关文章
const allPostsData = (await getCollection('blog')).map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
  published: p.data.published,
  slug: p.slug,
}));

const currentPostData = {
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  published: post.data.published,
  slug: post.slug,
};

// 简单的相关文章算法：标签匹配
const relatedPosts = post.data.tags.length > 0
  ? allPostsData
      .filter(p => {
        if (p.id === post.id) return false;
        return p.tags.some(tag => post.data.tags.includes(tag));
      })
      .slice(0, 3)
      .map(p => {
        const pubDate = new Date(p.published);
        return isNaN(pubDate.getTime()) 
          ? { ...p, published: new Date() }
          : { ...p, published: pubDate };
      })
  : [];

const sortedPosts = allPostsData.sort((a, b) => {
  return new Date(b.published).getTime() - new Date(a.published).getTime();
});

const postIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = sortedPosts[postIndex + 1];
const nextPost = sortedPosts[postIndex - 1];

// Extract TOC from markdown using AST
const ast = unified().use(remarkParse).parse(post.body);
const tocHeadings = [];

function extractHeadings(node) {
  if (node.type === 'heading' && node.depth === 2) {
    const text = toString(node);
    const id = text
      .toLowerCase()
      .replace(/[\w\s\u4e00-\u9fa5]/g, '-')
      .replace(/\s+/g, '-')
      .trim();
    tocHeadings.push({ id, text });
  }
  
  if (node.children) {
    node.children.forEach(extractHeadings);
  }
}

extractHeadings(ast);

// Render markdown to HTML using unified + remark
const markdownHtml = await unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkRehype)
  .use(rehypeStringify)
  .process(post.body);

const htmlContent = markdownHtml.value?.toString() || '';
---

<Layout title={`${post.data.title} - Edward Chen`}>
  <!-- Left TOC -->
  {tocHeadings.length > 0 && (
    <aside class="article-toc">
      <div class="toc-head">
        <span class="ct">{tocHeadings.length} 个章节</span>
      </div>
      
      <div class="toc-rail">
        <ul class="toc-list">
          {tocHeadings.map((heading) => (
            <li>
              <a href={`#${heading.id}`} class="toc-link">
                <span class="toc-t">{heading.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  )}
  
  <!-- Main Content -->
  <article class="article-content rise">
    <header class="hero">
      <div class="meta">
        <time datetime={post.data.pubDate?.toISOString() || ''}>
          {post.data.pubDate?.toLocaleDateString(lang, { year: 'numeric', month: '2-digit', day: '2-digit' }) || t('common.unpublished', lang)}
        </time>
        <span>•</span>
        <span>{t('post.readTime', lang, { minutes: Math.max(1, Math.ceil(post.body.length / 500)) })}</span>
        {post.data.pinned && (
          <>
            <span>•</span>
            <span class="text-accent font-medium">{t('blog.pinned', lang)}</span>
          </>
        )}
      </div>
      
      <h1>{post.data.title}</h1>
      <p class="lede mb-6">{post.data.description}</p>
      
      <div class="tags-container">
        <div id="tags-list" class="row gap-2 flex-wrap">
          {post.data.tags.map((tag, index) => (
            <a href={`/blog?tag=${encodeURIComponent(tag)}`} 
               class={`pill text-xs text-stone-600 bg-stone-100 hover:bg-stone-200 hover:text-stone-900 transition-colors px-3 py-1${index >= 10 ? ' hidden-tag' : ''}`}
               aria-label={`查看 ${tag} 标签的文章`}>
              #{tag}
            </a>
          ))}
        </div>
        {post.data.tags.length > 10 && (
          <button id="toggle-tags" class="toggle-tags-btn text-xs text-stone-600 hover:text-stone-900 mt-2" 
                  onclick="toggleTags()">
            <span class="show-text">展开 {post.data.tags.length - 10} 个标签</span>
            <span class="hide-text" style="display: none;">收起</span>
          </button>
        )}
      </div>
    </header>

    <section class="sec">
      <div class="markdown-body">
        <div set:html={htmlContent}></div>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <RelatedPosts posts={relatedPosts} />
    )}

    <nav class="sec flex justify-between items-center flex-wrap gap-4">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          ← {t('post.prev', lang, { title: prevPost.title })}
        </a>
      ) : (
        <a href="/blog" class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          ← {t('post.backToList', lang)}
        </a>
      )}
      
      {nextPost && (
        <a href={`/blog/${nextPost.slug}`} class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          {t('post.next', lang, { title: nextPost.title })} →
        </a>
      )}
    </nav>

    <!-- Giscus Comments -->
    <Giscus 
      repo="eddysaynun/edwardchen.com"
      repoId="R_kgDOScJuxg"
      category="Announcements"
      categoryId="DIC_kwDOScJuxs4C9Ddh"
      mapping="pathname"
      theme="noborder_light"
      lang="zh-CN"
      loading="lazy"
    />
  </article>

  <style>
    /* Left TOC - Timeline Style */
    .article-toc {
      position: fixed;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 200px;
      padding: 8px 0 8px 28px;
      overflow-y: auto;
      max-height: calc(100vh - 144px);
      font-family: var(--mono);
      font-size: 11.5px;
      color: var(--muted);
      z-index: 10;
    }

    .toc-head {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
      margin-bottom: 16px;
      white-space: nowrap;
      padding-left: 18px;
    }

    .toc-head::before {
      content: "// toc";
      color: var(--muted);
      margin-right: 8px;
    }

    .toc-head .ct {
      color: var(--muted-2);
    }

    .toc-rail {
      position: relative;
      padding-left: 18px;
    }

    .toc-rail::before {
      content: "";
      position: absolute;
      left: 4px;
      top: 4px;
      bottom: 4px;
      width: 1px;
      background: var(--line);
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc-link {
      display: block;
      text-decoration: none;
      color: var(--muted);
      padding: 5px 0;
      position: relative;
      transition: color 0.12s;
      line-height: 1.45;
    }

    .toc-link::before {
      content: "";
      position: absolute;
      left: -18px;
      top: 12px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--muted-2);
      transition: background 0.15s, transform 0.15s;
    }

    .toc-link:hover {
      color: var(--ink);
    }

    .toc-link:hover::before {
      background: var(--accent);
      transform: scale(1.4);
    }

    .toc-link.active {
      color: var(--ink);
    }

    .toc-link.active::before {
      background: var(--accent);
    }

    .toc-t {
      font-size: 11.5px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Main Content */
    .article-content {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    @media (min-width: 1024px) {
      .article-content {
        padding: 0 2rem;
      }
    }

    @media (min-width: 1200px) {
      .article-content {
        padding: 0 2.5rem;
      }
    }

    /* 移动端隐藏 TOC */
    @media (max-width: 1023px) {
      .article-toc {
        display: none;
      }
    }

    .markdown-body {
      font-size: 1.0625rem;
      line-height: 1.75;
      color: var(--ink);
    }

    .markdown-body h1,
    .markdown-body h2,
    .markdown-body h3,
    .markdown-body h4,
    .markdown-body h5,
    .markdown-body h6 {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .markdown-body h2 {
      font-size: 22px;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }

    .markdown-body h3 {
      font-size: 1.5rem;
    }

    .markdown-body h4 {
      font-size: 1.25rem;
    }

    .markdown-body p {
      margin-bottom: 1.5rem;
    }

    .markdown-body code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--surface);
      padding: 0.2em 0.4em;
      border-radius: 4px;
    }

    .markdown-body pre {
      margin-bottom: 1.5rem;
      padding: 1rem;
      background: var(--surface);
      border-radius: 8px;
      overflow-x: auto;
    }

    .markdown-body pre code {
      background: none;
      padding: 0;
    }

    .markdown-body a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .markdown-body blockquote {
      margin: 1.5rem 0;
      padding: 1rem 1.5rem;
      border-left: 3px solid var(--accent);
      background: var(--surface);
      font-style: italic;
    }

    .markdown-body img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 1.5rem 0;
    }

    .markdown-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }

    .markdown-body th,
    .markdown-body td {
      border: 1px solid var(--border);
      padding: 0.75rem;
      text-align: left;
    }

    .markdown-body th {
      background: var(--surface);
      font-weight: 600;
    }

    .markdown-body ul,
    .markdown-body ol {
      margin-bottom: 1.5rem;
      padding-left: 2rem;
    }

    .markdown-body li {
      margin-bottom: 0.5rem;
    }

    /* Tags toggle */
    .tags-container {
      margin-bottom: 1rem;
    }

    .toggle-tags-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
      color: var(--muted);
      transition: color 0.2s;
      text-align: left;
    }

    .toggle-tags-btn:hover {
      color: var(--ink);
    }

    .hidden-tag {
      display: none;
    }
  </style>

  <script is:inline>
    function toggleTags() {
      const tagsList = document.getElementById('tags-list');
      const hiddenTags = tagsList ? tagsList.querySelectorAll('.hidden-tag') : [];
      const showText = document.querySelector('.show-text');
      const hideText = document.querySelector('.hide-text');
      
      if (hiddenTags.length > 0) {
        // 展开
        hiddenTags.forEach(tag => tag.classList.remove('hidden-tag'));
        if (showText) showText.style.display = 'none';
        if (hideText) hideText.style.display = '';
      } else {
        // 收起
        const allTags = tagsList ? tagsList.querySelectorAll('a') : [];
        allTags.forEach((tag, index) => {
          if (index >= 10) {
            tag.classList.add('hidden-tag');
          }
        });
        if (showText) showText.style.display = '';
        if (hideText) hideText.style.display = 'none';
      }
    }
  </script>
</Layout>
