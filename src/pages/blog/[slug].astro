---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';
import remarkGfm from 'remark-gfm';
import { toString } from 'mdast-util-to-string';
import Giscus from '../../components/Giscus.astro';
import { t, getCurrentLang } from '../../utils/i18n';

const lang = getCurrentLang(false);

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = (await getCollection('blog')).find(p => p.slug === slug);

if (!post) {
  Astro.redirect('/blog');
}

const relatedPosts = post.data.tags.length > 0
  ? (await getCollection('blog'))
      .filter(p => {
        if (p.slug === slug) return false;
        return p.data.tags.some(tag => post.data.tags.includes(tag));
      })
      .slice(0, 3)
  : [];

const allPosts = await getCollection('blog');

const sortedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.pubDate || new Date(0);
  const dateB = b.data.pubDate || new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const postIndex = sortedPosts.findIndex(p => p.slug === slug);
const prevPost = sortedPosts[postIndex + 1];
const nextPost = sortedPosts[postIndex - 1];

// Extract TOC from markdown using AST
const ast = unified().use(remarkParse).parse(post.body);
const tocHeadings = [];

function extractHeadings(node) {
  if (node.type === 'heading' && node.depth === 2) {
    const text = toString(node);
    const id = text
      .toLowerCase()
      .replace(/[\w\s\u4e00-\u9fa5]/g, '-')
      .replace(/\s+/g, '-')
      .trim();
    tocHeadings.push({ id, text });
  }
  
  if (node.children) {
    node.children.forEach(extractHeadings);
  }
}

extractHeadings(ast);

// Render markdown to HTML using unified + remark
const markdownHtml = await unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkRehype)
  .use(rehypeStringify)
  .process(post.body);

const htmlContent = markdownHtml.value?.toString() || '';
---

<Layout title={`${post.data.title} - Edward Chen`}>
  <!-- Left TOC -->
  {tocHeadings.length > 0 && (
    <aside class="article-toc">
      <h3 class="toc-title">{t('blog.toc', lang)}</h3>
      <nav class="toc-nav">
        <ul>
          {tocHeadings.map((heading) => (
            <li>
              <a href={`#${heading.id}`} class="toc-link">
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
  
  <!-- Main Content -->
  <article class="article-content rise">
    <header class="hero">
      <div class="meta">
        <time datetime={post.data.pubDate?.toISOString() || ''}>
          {post.data.pubDate?.toLocaleDateString(lang, { year: 'numeric', month: '2-digit', day: '2-digit' }) || t('common.unpublished', lang)}
        </time>
        <span>•</span>
        <span>{t('post.readTime', lang, { minutes: Math.max(1, Math.ceil(post.body.length / 500)) })}</span>
        {post.data.pinned && (
          <>
            <span>•</span>
            <span class="text-accent font-medium">{t('blog.pinned', lang)}</span>
          </>
        )}
      </div>
      
      <h1>{post.data.title}</h1>
      <p class="lede mb-6">{post.data.description}</p>
      
      <div class="row gap-2 flex-wrap">
        {post.data.tags.map((tag) => (
          <a href={`/blog?tag=${encodeURIComponent(tag)}`} 
             class="pill text-xs text-stone-600 bg-stone-100 hover:bg-stone-200 hover:text-stone-900 transition-colors px-3 py-1"
             aria-label={`查看 ${tag} 标签的文章`}>
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <section class="sec">
      <div class="markdown-body">
        <div set:html={htmlContent}></div>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <section class="sec">
        <div class="sec-head">
          <h2>{t('post.related', lang)}</h2>
        </div>
        <div class="projects">
          {relatedPosts.map((relatedPost) => (
            <article class="project">
              <h4>
                <a href={`/blog/${relatedPost.slug}`}>{relatedPost.data.title}</a>
              </h4>
              <p>{relatedPost.data.description}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <nav class="sec flex justify-between items-center flex-wrap gap-4">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          ← {t('post.prev', lang, { title: prevPost.data.title })}
        </a>
      ) : (
        <a href="/blog" class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          ← {t('post.backToList', lang)}
        </a>
      )}
      
      {nextPost && (
        <a href={`/blog/${nextPost.slug}`} class="font-mono text-xs text-muted hover:text-ink transition-colors inline-flex items-center gap-2">
          {t('post.next', lang, { title: nextPost.data.title })} →
        </a>
      )}
    </nav>

    <!-- Giscus Comments -->
    <Giscus 
      repo="eddysaynun/edwardchen.com"
      repoId="R_kgDOScJuxg"
      category="Announcements"
      categoryId="DIC_kwDOScJuxs4C9Ddh"
      mapping="pathname"
      theme="noborder_light"
      lang="zh-CN"
      loading="lazy"
    />
  </article>

  <style>
    /* Left TOC */
    .article-toc {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 240px;
      padding: 100px 1rem 2rem 1rem;
      overflow-y: auto;
      background: var(--bg);
      z-index: 100;
      border-right: 1px solid var(--border);
    }

    .toc-title {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .toc-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc-nav li {
      margin-bottom: 0.5rem;
    }

    .toc-link {
      font-size: 0.875rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .toc-link:hover {
      color: var(--ink);
    }

    /* Main Content */
    .article-content {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    @media (min-width: 1024px) {
      .article-content {
        margin-left: 240px;
        margin-right: auto;
        padding: 0 2rem;
      }
    }

    @media (min-width: 1200px) {
      .article-content {
        padding: 0 2.5rem;
      }
    }

    .markdown-body {
      font-size: 1.0625rem;
      line-height: 1.75;
      color: var(--ink);
    }

    .markdown-body h1,
    .markdown-body h2,
    .markdown-body h3,
    .markdown-body h4,
    .markdown-body h5,
    .markdown-body h6 {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .markdown-body h2 {
      font-size: 22px;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }

    .markdown-body h3 {
      font-size: 1.5rem;
    }

    .markdown-body h4 {
      font-size: 1.25rem;
    }

    .markdown-body p {
      margin-bottom: 1.5rem;
    }

    .markdown-body code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--surface);
      padding: 0.2em 0.4em;
      border-radius: 4px;
    }

    .markdown-body pre {
      margin-bottom: 1.5rem;
      padding: 1rem;
      background: var(--surface);
      border-radius: 8px;
      overflow-x: auto;
    }

    .markdown-body pre code {
      background: none;
      padding: 0;
    }

    .markdown-body a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .markdown-body blockquote {
      margin: 1.5rem 0;
      padding: 1rem 1.5rem;
      border-left: 3px solid var(--accent);
      background: var(--surface);
      font-style: italic;
    }

    .markdown-body img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 1.5rem 0;
    }

    .markdown-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }

    .markdown-body th,
    .markdown-body td {
      border: 1px solid var(--border);
      padding: 0.75rem;
      text-align: left;
    }

    .markdown-body th {
      background: var(--surface);
      font-weight: 600;
    }

    .markdown-body ul,
    .markdown-body ol {
      margin-bottom: 1.5rem;
      padding-left: 2rem;
    }

    .markdown-body li {
      margin-bottom: 0.5rem;
    }
  </style>
</Layout>
